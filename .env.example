# ---- Webhook Inspector configuration ----

# PostgreSQL connection string. On Railway this is provided automatically by the
# Postgres plugin (reference it as ${{Postgres.DATABASE_URL}}).
DATABASE_URL=postgres://user:password@localhost:5432/webhook_inspector

# Port the HTTP server listens on. Railway injects this automatically.
PORT=3000

# How long captured requests are retained before auto-cleanup, in hours.
# Default 168 = 7 days.
RETENTION_HOURS=168

# Maximum number of body bytes stored per request. Larger bodies are truncated
# (the true size is still recorded). Default 1048576 = 1 MB.
MAX_BODY_BYTES=1048576

# Optional. If set, gates the web UI and management API behind a bearer token /
# cookie. Capture URLs (/hook/*) always stay public.
# ACCESS_TOKEN=changeme-super-secret

# Optional. Public base URL used to render capture URLs when behind a custom
# domain or reverse proxy, e.g. https://hooks.example.com
# PUBLIC_URL=https://hooks.example.com
