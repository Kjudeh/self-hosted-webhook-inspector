{
  "name": "webhook-inspector",
  "version": "1.0.0",
  "description": "Self-hosted webhook inspector, tester, and replay tool — an open-source alternative to webhook.site / Hookdeck.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/server/index.js",
  "scripts": {
    "build:server": "tsc -p tsconfig.json",
    "build:client": "node scripts/build-client.mjs",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server/index.js",
    "dev": "npm run build && node dist/server/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.3"
  }
}
